from functools import lru_cache

from pydantic_settings import SettingsConfigDict

from fast_agent_stack.config import BaseSettings


class Settings(BaseSettings):
    model_config = SettingsConfigDict(env_prefix="{{ project_name | upper }}_")

{%- if db == "sqlite" %}
    database_url: str = "sqlite+aiosqlite:///./{{ project_name }}.db"
{%- elif db == "postgres" %}
    database_url: str = "postgresql+asyncpg://user:password@localhost/{{ project_name }}"
{%- elif db == "mysql" %}
    database_url: str = "mysql+aiomysql://user:password@localhost/{{ project_name }}"
{%- endif %}
{%- if include_auth %}
    auth_backends: list[str] = [{%- if auth_backends == "jwt-and-session" %}"jwt", "session"{%- else %}"{{ auth_backends }}"{%- endif %}]
    secret_key: str = "change-me-in-production"
{%- endif %}
{%- if include_admin %}
    admin_secret_key: str = ""
{%- endif %}
{%- if include_auth or include_rate_limit %}
    redis_url: str = "redis://localhost:6379/0"
{%- endif %}
{%- if include_rate_limit %}
    include_rate_limit: bool = True
{%- endif %}


@lru_cache
def get_settings() -> Settings:
    return Settings()
