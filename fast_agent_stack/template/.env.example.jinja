# {{ project_name }} environment configuration
# Copy to .env and fill in values — never commit .env to version control
{%- if db == "sqlite" %}
{{ project_name | upper }}_DATABASE_URL=sqlite+aiosqlite:///./{{ project_name }}.db
{%- elif db == "postgres" %}
{{ project_name | upper }}_DATABASE_URL=postgresql+asyncpg://user:password@localhost/{{ project_name }}
{%- elif db == "mysql" %}
{{ project_name | upper }}_DATABASE_URL=mysql+aiomysql://user:password@localhost/{{ project_name }}
{%- endif %}
{{ project_name | upper }}_DEBUG=false
{%- if include_auth %}
{{ project_name | upper }}_SECRET_KEY=change-me-in-production
{%- endif %}
{%- if task_broker == "redis" or include_rate_limit %}
{{ project_name | upper }}_REDIS_URL=redis://localhost:6379/0
{%- endif %}
{%- if secrets_backend == "aws" %}
SECRETS_BACKEND=aws
SECRETS_AWS_SECRET_ID={{ project_name }}/secrets
SECRETS_AWS_REGION=us-east-1
{%- elif secrets_backend == "gcp" %}
SECRETS_BACKEND=gcp
SECRETS_GCP_PROJECT_ID=your-gcp-project-id
{%- endif %}
# LLM and embedding backends (optional - point at Ollama or leave empty to use OpenAI defaults)
# {{ project_name | upper }}_LLM_BASE_URL=http://localhost:11434/v1
# {{ project_name | upper }}_LLM_MODEL=llama3.2
# {{ project_name | upper }}_LLM_API_KEY=ollama
# {{ project_name | upper }}_EMBEDDING_PROVIDER=openai
# {{ project_name | upper }}_EMBEDDING_BASE_URL=http://localhost:11434/v1
# {{ project_name | upper }}_EMBEDDING_MODEL=nomic-embed-text
# {{ project_name | upper }}_EMBEDDING_API_KEY=ollama
